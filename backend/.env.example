# Backend environment variables for Job Card Agent

# Authentication
JWT_SECRET=
ACCESS_TOKEN_SECRET=

# Node.js / App
NODE_ENV=development
PORT=5000

# Database configuration (development)
PGHOST=localhost
PGPORT=5432
PGDATABASE=newjobcard
PGUSER=postgres
PGPASSWORD=0000
# Production example
# DATABASE_URL=postgresql://username:password@host:port/database

# Storage provider options: local, azure
STORAGE_PROVIDER=local

# Azure Blob Storage (production)
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_CONTAINER_SIGNATURES=signatures
# AZURE_STORAGE_CONTAINER_DOCUMENTS=approved-documents

# Logging
LOG_LEVEL=info

# Worker settings
WORKER_ENABLED=true
WORKER_POLL_INTERVAL_MS=5000

# Azure App Service / Key Vault readiness
# AZURE_KEY_VAULT_URI=https://your-keyvault.vault.azure.net/
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_TENANT_ID=

# OpenAI integration for job summaries and CRM note generation
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-3.5-turbo

# n8n webhook configuration for approval-to-CRM workflows
# N8N_WEBHOOK_URL=https://your-n8n-host/webhook/job-approval
# N8N_JOB_APPROVAL_WEBHOOK_URL=https://your-n8n-host/webhook/job-approval
