JWT_SECRET=your-super-secret-jwt-key-change-in-production-12345
ACCESS_TOKEN_SECRET=your-access-token-secret
NODE_ENV=development
PORT=5000

# Database Configuration
# For production, use DATABASE_URL
# DATABASE_URL=postgresql://username:password@host:port/database
PGHOST=localhost
PGPORT=5432
PGDATABASE=newjobcard
PGUSER=postgres
PGPASSWORD=0000

# Storage Configuration
STORAGE_PROVIDER=local

# Azure Blob Storage (for production)
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=youraccount;AccountKey=yourkey;EndpointSuffix=core.windows.net
# AZURE_STORAGE_CONTAINER_SIGNATURES=signatures
# AZURE_STORAGE_CONTAINER_DOCUMENTS=approved-documents

# Logging Configuration
LOG_LEVEL=info

# Worker Configuration
WORKER_ENABLED=true
WORKER_POLL_INTERVAL_MS=5000

# Azure App Service Configuration (for production)
# WEBSITE_NODE_DEFAULT_VERSION=18
# AZURE_KEY_VAULT_URI=https://your-keyvault.vault.azure.net/
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret
# AZURE_TENANT_ID=your-tenant-id